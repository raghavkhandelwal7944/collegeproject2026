*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# Testing / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# MyPy / Pyright type stubs cache
.mypy_cache/
.dmypy.json
.pyright/

